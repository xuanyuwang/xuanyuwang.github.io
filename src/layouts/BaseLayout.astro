---
interface Props {
  title: string;
  description?: string;
}

import "../styles/global.css";

const { title, description = "Personal site and blog" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">Xuanyu Wang</a>
        <nav class="nav">
          <a href="/blog/">Blog</a>
          <a href="/apps/">Apps</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
